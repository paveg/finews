{
  "name": "worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply finews --local",
    "db:migrate:remote": "wrangler d1 migrations apply finews --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@finews/shared": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "fast-xml-parser": "^5.0.0",
    "hono": "^4.12.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20260523.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
